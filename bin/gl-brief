#!/usr/bin/env bash
# Build a markdown brief for a ticket (description, comments, branch, PR state)
# at $(gl_brief_path id). Prints the path on stdout.
set -euo pipefail
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=gl-lib.sh
. "$DIR/gl-lib.sh"

id="${1:?usage: gl-brief <TICKET-ID>}"
out="$(gl_brief_path "$id")"
token="$(gl_token)"

read -r -d '' QUERY <<'GQL' || true
query($id: String!) {
  issue(id: $id) {
    identifier
    title
    url
    branchName
    description
    state { name }
    assignee { name }
    comments(first: 30) {
      nodes { body createdAt user { name } }
    }
  }
}
GQL

resp="$(curl -s --max-time 20 https://api.linear.app/graphql \
  -H "Authorization: $token" -H "Content-Type: application/json" \
  -d "$(jq -n --arg q "$QUERY" --arg id "$id" '{query: $q, variables: {id: $id}}')")"

branch="$(gl_ticket_field "$id" .branch || true)"
pr_number="$(gl_ticket_field "$id" .pr.number || true)"
pr_state="$(gl_ticket_field "$id" .pr.state || true)"
pr_checks="$(gl_ticket_field "$id" .pr.checks || true)"

{
  printf '# Task brief: %s\n\n' "$id"
  printf '%s' "$resp" | jq -r '.data.issue |
    "**Title:** " + .title + "\n" +
    "**State:** " + (.state.name // "?") + "\n" +
    "**URL:** " + .url + "\n" +
    "**Branch:** " + (.branchName // "?") + "\n"'

  if [ -n "$pr_number" ] && [ "$pr_number" != "null" ] && [ -n "$pr_number" ]; then
    printf '**PR:** #%s (%s, checks: %s)\n' "$pr_number" "${pr_state:-?}" "${pr_checks:-?}"
  else
    printf '**PR:** none yet\n'
  fi

  printf '\n## Description\n\n'
  printf '%s' "$resp" | jq -r '.data.issue.description // "_(no description)_"'

  printf '\n\n## Comments\n\n'
  printf '%s' "$resp" | jq -r '
    (.data.issue.comments.nodes // []) as $c
    | if ($c | length) == 0 then "_(no comments)_"
      else ($c | reverse | .[] | "**" + (.user.name // "someone") + "** (" + .createdAt + "):\n" + .body + "\n")
      end'
} > "$out"

printf '%s\n' "$out"
