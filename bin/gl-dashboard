#!/usr/bin/env python3
"""Linear ticket status page for the ghostty-linear tmux workflow.

Lists assigned + active tickets, badges the ones with a live claude session,
shows PR # + CI status. Up/Down paginate, Enter opens/attaches, y splits.
"""
import curses
import json
import os
import re
import subprocess
import time

TICKET_RE = re.compile(r"^[A-Za-z]+-\d+$")

HOME = os.path.expanduser("~")
CACHE = os.environ.get("GL_CACHE", os.path.join(HOME, ".cache/ghostty-linear"))
BIN = os.path.dirname(os.path.abspath(__file__))
TICKETS = os.path.join(CACHE, "tickets.json")
AGENTS = os.path.join(CACHE, "agents.json")
SELECTED = os.path.join(CACHE, "selected")
ORDER = os.path.join(CACHE, "order")
SESSION = os.environ.get("GL_SESSION", "hazel")
TMUX = os.environ.get("TMUX_BIN") or "tmux"

REFETCH_SECONDS = 180


def load_tickets():
    try:
        with open(TICKETS) as f:
            return json.load(f)
    except (OSError, ValueError):
        return []


def load_agents():
    """Registered ad-hoc free agents: [{id,name}, ...]."""
    try:
        with open(AGENTS) as f:
            data = json.load(f)
        return data if isinstance(data, list) else []
    except (OSError, ValueError):
        return []


def order_tickets(tickets, live):
    """Tickets with a live session float to the top; order is otherwise
    preserved (stable sort)."""
    return sorted(tickets, key=lambda t: t.get("id", "?") not in live)


def build_items(tickets, agents):
    """Flat navigable list: tickets first, then free agents."""
    items = [{"kind": "ticket", "id": t.get("id", "?"), "data": t} for t in tickets]
    items += [{"kind": "agent", "id": a.get("id", "?"), "data": a} for a in agents]
    return items


def build_rows(tickets, agents):
    """Display rows, item_idx aligned to build_items():
       ("ticket", t, i) | ("header", label) | ("agent", a, i)."""
    rows, i = [], 0
    for t in tickets:
        rows.append(("ticket", t, i)); i += 1
    rows.append(("header", "Free agents  (a add · x remove)"))
    for a in agents:
        rows.append(("agent", a, i)); i += 1
    return rows


def live_tickets():
    try:
        out = subprocess.run(
            [TMUX, "list-windows", "-t", SESSION, "-F",
             "#{@ticket}|#{window_name}|#{@shown}"],
            capture_output=True, text=True, timeout=2,
        )
        ids = set()
        for ln in out.stdout.splitlines():
            opt, name, shown = (ln.split("|", 2) + ["", "", ""])[:3]
            if opt.strip():
                ids.add(opt.strip())
            elif name.strip():
                first = name.split(" ", 1)[0]
                if TICKET_RE.match(first):
                    ids.add(first)
            # A ticket joined into the cockpit has no standalone window, but is
            # very much live — surface it via the cockpit's @shown option.
            if shown.strip():
                ids.add(shown.strip())
        return ids
    except Exception:
        return set()


def cockpit_shown():
    """Ticket currently joined into the cockpit's right pane ("" if none)."""
    try:
        out = subprocess.run(
            [TMUX, "list-windows", "-t", SESSION, "-F", "#{@shown}"],
            capture_output=True, text=True, timeout=2,
        )
        for ln in out.stdout.splitlines():
            if ln.strip():
                return ln.strip()
    except Exception:
        pass
    return ""


def write_selected(ticket_id):
    try:
        with open(SELECTED, "w") as f:
            f.write(ticket_id + "\n")
    except OSError:
        pass


def read_selected():
    try:
        with open(SELECTED) as f:
            return f.read().strip()
    except OSError:
        return ""


def run_bg(args):
    subprocess.Popen(args, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def mark_cockpit():
    """Tag this dashboard's window as the cockpit and record its pane id, so
    gl-split/gl-open can join/break ticket panes alongside it."""
    pane = os.environ.get("TMUX_PANE")
    if not pane:
        return
    for opt, val in (("@cockpit", "1"), ("@dashpane", pane)):
        try:
            subprocess.run([TMUX, "set-window-option", "-t", pane, opt, val],
                           stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                           timeout=2)
        except Exception:
            pass
    # The cockpit is never a ticket window; clear any stray @ticket so it isn't
    # mistaken for one (gl_window_for) or shown as a live session badge.
    try:
        subprocess.run([TMUX, "set-window-option", "-t", pane, "-u", "@ticket"],
                       stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, timeout=2)
    except Exception:
        pass


def fetch_blocking(stdscr):
    h, w = stdscr.getmaxyx()
    msg = " Refreshing from Linear… "
    try:
        stdscr.addstr(h // 2, max(0, (w - len(msg)) // 2), msg, curses.A_REVERSE)
        stdscr.refresh()
    except curses.error:
        pass
    subprocess.run([os.path.join(BIN, "gl-fetch")], capture_output=True)


def pr_cells(pr):
    """Return (pr_text, pr_color, review_text, review_color)."""
    if not pr or not pr.get("number"):
        return ("", 0, "", 0)
    num = pr.get("number")
    checks = pr.get("checks", "none")
    state = (pr.get("state") or "OPEN").upper()
    draft = pr.get("draft")
    mark = {"pass": "✓", "fail": "✗", "pending": "•", "none": "·"}.get(checks, "·")
    label = "draft" if draft else state.lower()
    color = {"pass": 3, "fail": 4, "pending": 5}.get(checks, 0)
    if state == "MERGED":
        color, label = 6, "merged"
    elif state == "CLOSED":
        color, label = 4, "closed"
    review = pr.get("review", "")
    rtext, rcolor = {
        "approved": ("appr", 3),
        "changes": ("chg!", 4),
        "review": ("req", 5),
    }.get(review, ("", 0))
    if pr.get("mergeable") == "CONFLICTING":
        rtext, rcolor = "conflx", 4
    return (f"#{num} {mark} {label}", color, rtext, rcolor)


def add_seg(stdscr, y, x, text, width, color, selected, maxw):
    """Write a fixed-width segment, return the next x."""
    cell = text[:width].ljust(width)
    if x >= maxw:
        return x
    cell = cell[:maxw - x]
    attr = curses.A_REVERSE if selected else (curses.color_pair(color) if color else 0)
    try:
        stdscr.addstr(y, x, cell, attr)
    except curses.error:
        pass
    return x + len(cell)


def draw(stdscr, rows, idx, top, live, status_line, shown, n_tickets, n_agents):
    stdscr.erase()
    h, w = stdscr.getmaxyx()
    title = "  Linear — my active tickets"
    count = f"{n_tickets} tickets · {n_agents} agents · {len(live)} live  "
    stdscr.attron(curses.A_BOLD)
    stdscr.addnstr(0, 0, title.ljust(max(0, w - len(count))) + count, w - 1)
    stdscr.attroff(curses.A_BOLD)
    stdscr.hline(1, 0, curses.ACS_HLINE, w)

    body_top = 2
    body_h = max(1, h - body_top - 1)
    maxw = w - 1

    for row, entry in enumerate(rows[top:top + body_h]):
        y = body_top + row
        kind = entry[0]

        if kind == "header":
            try:
                stdscr.attron(curses.A_DIM)
                stdscr.addnstr(y, 0, ("── " + entry[1] + " ").ljust(maxw, "─")[:maxw], maxw)
                stdscr.attroff(curses.A_DIM)
            except curses.error:
                pass
            continue

        _, obj, i = entry
        sel = (i == idx)
        if sel:
            stdscr.attron(curses.A_REVERSE)
            try:
                stdscr.addstr(y, 0, " ".ljust(maxw))
            except curses.error:
                pass
            stdscr.attroff(curses.A_REVERSE)

        is_live = obj.get("id", "?") in live
        x = add_seg(stdscr, y, 0, f" {'●' if is_live else ' '} ", 3, 3 if is_live else 0, sel, maxw)
        if kind == "ticket":
            state = obj.get("state") or ""
            prtext, prcolor, rtext, rcolor = pr_cells(obj.get("pr"))
            title_w = max(10, maxw - 3 - 11 - 13 - 16 - 7)
            x = add_seg(stdscr, y, x, obj.get("id", "?"), 11, 0, sel, maxw)
            x = add_seg(stdscr, y, x, state, 13, 0, sel, maxw)
            x = add_seg(stdscr, y, x, prtext, 16, prcolor, sel, maxw)
            x = add_seg(stdscr, y, x, rtext, 7, rcolor, sel, maxw)
            x = add_seg(stdscr, y, x, obj.get("title") or "", title_w, 0, sel, maxw)
        else:  # agent
            x = add_seg(stdscr, y, x, obj.get("id", "?"), 11, 0, sel, maxw)
            name = obj.get("name") or ""
            if name == obj.get("id"):
                name = "claude (free agent)"
            x = add_seg(stdscr, y, x, name, max(10, maxw - x), 0, sel, maxw)

    split = f" · ▶ {shown}" if shown else ""
    footer = (" ↑/↓ move · ⏎ open · y split" + split +
              " · a add · x remove · g back · r refresh · q detach ")
    try:
        stdscr.attron(curses.A_DIM)
        stdscr.addnstr(h - 1, 0, (status_line or footer)[:maxw], maxw)
        stdscr.attroff(curses.A_DIM)
    except curses.error:
        pass
    stdscr.refresh()


def main(stdscr):
    mark_cockpit()
    curses.curs_set(0)
    curses.use_default_colors()
    for i, fg in [(3, curses.COLOR_GREEN), (4, curses.COLOR_RED),
                  (5, curses.COLOR_YELLOW), (6, curses.COLOR_MAGENTA)]:
        try:
            curses.init_pair(i, fg, -1)
        except curses.error:
            pass
    # Short poll so cycling feels live; expensive work (tmux queries, re-marking
    # the cockpit) is throttled below so we don't spawn subprocesses 8×/sec.
    stdscr.timeout(120)
    POLL_SECS = 1.0          # how often to re-query tmux for live/split state
    MARK_SECS = 2.0          # how often to re-assert @cockpit/@dashpane
    PREVIEW_DEBOUNCE = 0.22  # settle time before previewing the selection

    tickets = load_tickets()
    if not tickets:
        fetch_blocking(stdscr)
        tickets = load_tickets()
    agents = load_agents()
    items = build_items(tickets, agents)

    idx = 0
    sel = read_selected()
    if sel:
        for i, it in enumerate(items):
            if it["id"] == sel:
                idx = i
                break
    top = 0
    now = time.time()
    last_fetch = now
    last_poll = 0.0
    last_mark = 0.0
    live = set()
    shown = ""
    pending = None       # id whose preview is waiting to settle
    pending_ts = 0.0
    status_line = ""
    last_order = None

    while True:
        now = time.time()

        if now - last_mark >= MARK_SECS:
            mark_cockpit()
            last_mark = now

        if now - last_poll >= POLL_SECS:
            live = live_tickets()
            shown = cockpit_shown()
            agents = load_agents()
            last_poll = now
            if now - last_fetch > REFETCH_SECONDS:
                fetch_blocking(stdscr)
                tickets = load_tickets()
                last_fetch = time.time()

        tickets_view = order_tickets(tickets, live)   # live sessions on top
        items = build_items(tickets_view, agents)
        rows = build_rows(tickets_view, agents)
        n = len(items)
        idx = max(0, min(idx, n - 1)) if n else 0

        # Publish the visible order so gl-cycle (cmd+`) matches the screen.
        order = "\n".join(it["id"] for it in items)
        if order != last_order:
            try:
                with open(ORDER, "w") as f:
                    f.write(order + ("\n" if order else ""))
            except OSError:
                pass
            last_order = order

        h, _ = stdscr.getmaxyx()
        body_h = max(1, h - 3)

        # Follow the shared selection so cmd+` / gl-cycle (separate processes)
        # move the highlight here too.
        sel = read_selected()
        if sel and n and (idx >= n or items[idx]["id"] != sel):
            for i, it in enumerate(items):
                if it["id"] == sel:
                    idx = i
                    break

        # Keep the selected item's display row on screen (rows include the
        # non-selectable "Free agents" header).
        sel_row = next((r for r, e in enumerate(rows) if e[0] != "header" and e[2] == idx), 0)
        if sel_row < top:
            top = sel_row
        elif sel_row >= top + body_h:
            top = sel_row - body_h + 1
        top = max(0, min(top, max(0, len(rows) - 1)))

        if pending is not None and now - pending_ts >= PREVIEW_DEBOUNCE:
            run_bg([os.path.join(BIN, "gl-preview"), pending])
            pending = None

        draw(stdscr, rows, idx, top, live, status_line, shown, len(tickets), len(agents))
        status_line = ""

        try:
            c = stdscr.getch()
        except KeyboardInterrupt:
            c = -1

        if c == -1:
            continue

        cur = items[idx] if n else None
        moved = False
        if c in (curses.KEY_UP, ord("k")):
            idx = max(0, idx - 1); moved = True
        elif c in (curses.KEY_DOWN, ord("j")):
            idx = min(n - 1, idx + 1) if n else 0; moved = True
        elif c == curses.KEY_NPAGE:
            idx = min(n - 1, idx + body_h) if n else 0; moved = True
        elif c == curses.KEY_PPAGE:
            idx = max(0, idx - body_h); moved = True
        elif c in (curses.KEY_ENTER, 10, 13):
            if cur:
                run_bg([os.path.join(BIN, "gl-open"), cur["id"]])
                pending = None
        elif c == ord("y"):
            if cur:
                run_bg([os.path.join(BIN, "gl-split"), cur["id"]])
                pending = None
        elif c == ord("a"):
            run_bg([os.path.join(BIN, "gl-agent"), "add"])
            status_line = " spawning free agent… "
            last_poll = 0.0     # reload the agent list promptly
        elif c == ord("x"):
            if cur and cur["kind"] == "agent":
                run_bg([os.path.join(BIN, "gl-agent"), "remove", cur["id"]])
                status_line = f" removed {cur['id']} "
                last_poll = 0.0
            else:
                status_line = " x removes a free agent (select one) "
        elif c == ord("g"):
            run_bg([os.path.join(BIN, "gl-return")])
        elif c == ord("o"):
            if cur and cur["kind"] == "ticket" and cur["data"].get("url"):
                run_bg(["open", cur["data"]["url"]])
        elif c == ord("r"):
            fetch_blocking(stdscr)
            tickets = load_tickets()
            last_fetch = time.time()
            status_line = " refreshed "
        elif c == ord("q"):
            subprocess.run([TMUX, "detach-client"])

        if moved and n:
            write_selected(items[idx]["id"])
            pending = items[idx]["id"]
            pending_ts = now


if __name__ == "__main__":
    while True:
        try:
            curses.wrapper(main)
            break
        except KeyboardInterrupt:
            continue
        except Exception as e:  # keep the window alive on unexpected errors
            print(f"\n[ghostty-linear] dashboard error: {e}\nRestarting in 2s… (Ctrl-C to stop)")
            time.sleep(2)
