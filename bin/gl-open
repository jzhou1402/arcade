#!/usr/bin/env bash
# cmd+Enter: ensure a claude session for the ticket and put the cursor in it.
# In split view: if the ticket already has a session, full-screen (zoom) it; if
# it was blank/new, start the session and land in the normal split (un-zoomed).
# Outside split: ensure its window exists and switch to it full-screen.
# usage: gl-open [TICKET-ID]   (defaults to the dashboard's current selection)
set -euo pipefail
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=gl-lib.sh
. "$DIR/gl-lib.sh"

id="${1:-$(cat "$GL_SELECTED" 2>/dev/null || true)}"
if [ -z "$id" ]; then gl_log "No ticket selected."; exit 1; fi
if [ -z "$TMUX_BIN" ]; then gl_log "tmux not found."; exit 1; fi

if gl_split_active; then
  cockpit="$(gl_cockpit_window)"
  # Was there already a session? (a standalone window, or the one shown now)
  was_live=0
  if [ -n "$(gl_window_for "$id")" ]; then
    was_live=1
  elif [ "$(gl_shown_ticket "$cockpit")" = "$id" ] && [ "$(gl_shown_kind "$cockpit")" = "claude" ]; then
    was_live=1
  fi

  gl_show_claude "$id"               # creates the session if it was blank/new
  claude="$(gl_cockpit_claude_pane "$cockpit")"
  if [ -n "$claude" ]; then "$TMUX_BIN" select-pane -t "$claude"; fi   # cursor into claude

  if [ "$was_live" = "1" ] && [ -n "$claude" ]; then
    # Already had a session -> full-screen it. cmd+escape / Ctrl-b z restores.
    if [ "$("$TMUX_BIN" display-message -p -t "$cockpit" '#{window_zoomed_flag}')" != "1" ]; then
      "$TMUX_BIN" resize-pane -Z -t "$claude"
    fi
  fi
else
  win="$(gl_ensure_window "$id")"
  "$TMUX_BIN" select-window -t "$win"
fi

printf '%s\n' "$id" > "$GL_SELECTED"
